YOUTUBE_API_KEY=
# Pooler (app runtime, port 6543) — add ?pgbouncer=true for Supabase transaction pooler
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection (prisma db push / migrate)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"
# Если задан, админка: /admin?key=<значение> и те же key для /api/admin/*
ADMIN_SECRET=

# DeepSeek (OpenAI-совместимый API), только сервер
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Стоимость одной генерации сценария во внутреннем кошельке токенов
SCRIPT_GENERATION_TOKEN_COST=20
