YOUTUBE_API_KEY=
DATABASE_URL="file:./dev.db"
# Если задан, админка: /admin?key=<значение> и те же key для /api/admin/*
ADMIN_SECRET=

# DeepSeek (OpenAI-совместимый API), только сервер
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
# Стоимость одной генерации сценария во внутреннем кошельке токенов
SCRIPT_GENERATION_TOKEN_COST=20
