generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id        String @id @default(cuid())
  platform  String @default("youtube")
  externalId String

  url           String
  title         String
  description   String?
  thumbnailUrl  String?
  videoUrl      String?
  publishedAt   DateTime
  durationSeconds Int
  views         Int     @default(0)
  likes         Int     @default(0)
  comments      Int     @default(0)
  shares        Int     @default(0)
  language      String?
  region        String?
  sourceQuery   String?
  niche         String?

  ageHours         Float @default(0)
  relevanceScore   Float @default(0)
  rawScore         Float @default(0)
  /** Нормализованная оценка 1–99 (легаси, выравнивается с rating). */
  score            Int   @default(1)
  /** Оценка 0–99 по универсальной формуле. */
  rating           Int   @default(0)
  viralScore       Float @default(0)
  viewsPerHour     Float @default(0)
  engagementRate   Float @default(0)

  channelId     String?
  channelTitle  String?

  authorUsername     String?
  authorDisplayName  String?
  authorAvatarUrl    String?
  subtitlesUrl       String?
  followerCount      Int?
  retentionRate      Float?
  usefulRaw          String?
  cacheUrl           String?

  transcriptText       String?
  transcriptJson       Json?
  /** null | processing | ready | failed */
  transcriptStatus     String?
  /** subtitles | groq_whisper */
  transcriptSource     String?
  transcriptLanguage   String?
  transcriptCreatedAt  DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastFetchedAt DateTime?

  scriptChatReferences ScriptChatReference[]

  @@unique([platform, externalId])
  @@index([sourceQuery])
  @@index([platform])
}

model SearchCache {
  id           String   @id @default(cuid())
  cacheKey     String   @unique
  query        String
  region       String?
  language     String?
  period       String?
  sort         String?
  videoIdsJson String
  createdAt    DateTime @default(now())
  expiresAt    DateTime
}

model CompetitorAccount {
  id                String            @id @default(cuid())
  userId            String
  user              SessionUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          String
  externalId        String
  username          String?
  handle            String?
  displayName       String?
  profileUrl        String
  avatarUrl         String?
  description       String?
  uploadsPlaylistId String?
  /** Курсор TikHub v2 fetch_user_reels, если после загрузки остались страницы. */
  lastReelsPaginationToken String?
  addedAt           DateTime          @default(now())
  lastSyncedAt      DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  videos     CompetitorVideo[]
  dailySyncs CompetitorDailySync[]

  @@unique([userId, platform, externalId])
  @@index([userId])
}

model CompetitorDailySync {
  id             String            @id @default(cuid())
  userId         String
  user           SessionUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitorId   String
  competitor     CompetitorAccount @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  /** UTC YYYY-MM-DD */
  syncDate       String
  chargedTokens  Int
  chargedAt      DateTime
  syncedAt       DateTime?
  status         String
  error          String?

  @@unique([userId, competitorId, syncDate])
  @@index([userId, syncDate])
}

model CompetitorVideo {
  id           String            @id @default(cuid())
  competitorId String
  competitor   CompetitorAccount @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  platform        String
  externalId      String
  url             String
  title           String
  description     String?
  thumbnailUrl    String?
  videoUrl        String?
  subtitlesUrl    String?
  usefulRaw       String?
  publishedAt     DateTime
  durationSeconds Int
  views           Int     @default(0)
  likes           Int     @default(0)
  comments        Int     @default(0)
  shares          Int     @default(0)
  authorUsername     String?
  authorDisplayName  String?
  authorAvatarUrl    String?
  score           Int     @default(1)
  viralScore      Float   @default(0)
  viewsPerHour    Float   @default(0)
  engagementRate  Float   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastFetchedAt   DateTime?

  @@unique([competitorId, platform, externalId])
}

/** Анонимный пользователь по httpOnly session id (не хранить баланс в cookie). */
model SessionUser {
  id         String   @id @default(cuid())
  sessionKey String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userTokenBalance     UserTokenBalance?
  tokenTransactions    TokenTransaction[]
  savedVideos          SavedVideo[]
  competitorAccounts   CompetitorAccount[]
  competitorDailySyncs CompetitorDailySync[]
  scriptChats          ScriptChat[]
  scriptUserProfile    ScriptUserProfile?
}

/** Настройки сценариста для генерации (одна запись на session user). */
model ScriptUserProfile {
  id              String      @id @default(cuid())
  userId          String      @unique
  user            SessionUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation      String      @default("")
  targetAudience  String      @default("")
  tone            String      @default("")
  cta             String      @default("")
  restrictions    String      @default("")
  /** Свободный текст профиля для сценариев (приоритет над полями выше). */
  profileText     String      @default("")
  updatedAt       DateTime    @updatedAt

  @@index([userId])
}

model ScriptChat {
  id        String         @id @default(cuid())
  userId    String
  user      SessionUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String         @default("Новый чат")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  ScriptMessage[]
  references ScriptChatReference[]

  @@index([userId, updatedAt])
}

model ScriptChatReference {
  id                  String     @id @default(cuid())
  chatId              String
  chat                ScriptChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  /** Связь с общей таблицей Video (транскрипт подтягивается отсюда). */
  videoId             String?
  video               Video?     @relation(fields: [videoId], references: [id], onDelete: SetNull)
  savedVideoId        String?
  competitorVideoId   String?

  platform            String
  externalId          String
  title               String
  thumbnailUrl        String?
  videoUrl            String?
  url                 String
  authorUsername      String?
  authorDisplayName   String?
  views               Int        @default(0)
  rating              Int        @default(0)
  durationSeconds     Int?
  publishedAt         DateTime?
  description         String?
  /** Снимок источника транскрипта на момент добавления. */
  transcriptSource    String?
  createdAt           DateTime   @default(now())

  @@unique([chatId, platform, externalId])
  @@index([chatId])
  @@index([videoId])
}

model ScriptMessage {
  id               String     @id @default(cuid())
  chatId           String
  chat             ScriptChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  /** user | assistant | system (system — импорт контекста ролика) */
  role             String
  content          String
  /** id строки SavedVideo при импорте */
  savedVideoId     String?
  createdAt        DateTime   @default(now())

  @@index([chatId, createdAt])
}

model SavedVideo {
  id                 String      @id @default(cuid())
  userId             String
  user               SessionUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform           String
  externalId         String
  title              String
  description        String?
  url                String
  videoUrl           String?
  thumbnailUrl       String?
  authorUsername     String?
  authorDisplayName  String?
  authorAvatarUrl    String?
  views              Int?
  likes              Int?
  comments           Int?
  shares             Int?
  rating             Int?
  publishedAt        DateTime?
  durationSeconds    Int?
  sourceType         String?
  sourceId           String?
  createdAt          DateTime    @default(now())

  @@unique([userId, platform, externalId])
  @@index([userId, createdAt])
}

model UserTokenBalance {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      SessionUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int        @default(12400)
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      SessionUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  /** Отрицательное — списание, положительное — начисление. */
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
}

model AdminEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  level     String
  type      String
  message   String
  sessionId String?
  userId    String?
  metaJson  String?

  @@index([createdAt])
  @@index([level])
  @@index([type])
}
